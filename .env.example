# ============================================================
# TCM — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Environment ---
NODE_ENV=development                         # development | staging | production

# --- PostgreSQL (per-store connection strings) ---
DATABASE_URL_IDENTITY_VAULT=postgresql://user:pass@localhost:5432/tcm_identity_vault
DATABASE_URL_CREDENTIAL_MIRROR=postgresql://user:pass@localhost:5432/tcm_credential_mirror
DATABASE_URL_OUTCOME_STORE=postgresql://user:pass@localhost:5432/tcm_outcome_store
DATABASE_URL_AUDIT_LOG=postgresql://user:pass@localhost:5432/tcm_audit_log
DATABASE_URL_SYNC_PIPELINE=postgresql://user:pass@localhost:5432/tcm_sync_pipeline
DATABASE_URL_CHAIN_REGISTRY=postgresql://user:pass@localhost:5432/tcm_chain_registry
DATABASE_URL_VOCAB_REGISTRY=postgresql://user:pass@localhost:5432/tcm_vocab_registry
DATABASE_URL_COMMERCIAL=postgresql://user:pass@localhost:5432/tcm_commercial
DATABASE_URL_KYC_WORKFLOW=postgresql://user:pass@localhost:5432/tcm_kyc_workflow
DATABASE_URL_DOC_ATTESTATION=postgresql://user:pass@localhost:5432/tcm_doc_attestation
DATABASE_URL_SUPPORT=postgresql://user:pass@localhost:5432/tcm_support
DATABASE_URL_ANALYTICS_FEED=postgresql://user:pass@localhost:5432/tcm_analytics_feed
DATABASE_URL_BILLING=postgresql://user:pass@localhost:5432/tcm_billing

# --- Blockchain / RPC ---
ALCHEMY_API_KEY=
ALCHEMY_RPC_URL_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/
ALCHEMY_RPC_URL_AMOY=https://polygon-amoy.g.alchemy.com/v2/
ALCHEMY_RPC_URL_MUMBAI=https://polygon-mumbai.g.alchemy.com/v2/
FALLBACK_RPC_URL_POLYGON=
TCT_CREDENTIAL_CONTRACT_ADDRESS=
TCT_OUTCOME_REGISTRY_ADDRESS=
CHAIN_ID_POLYGON=137
CHAIN_ID_AMOY=80002
CHAIN_ID_MUMBAI=80001

# Finality thresholds (blocks)
FINALITY_SOFT=32
FINALITY_OPERATIONAL=64
FINALITY_AUDIT=128

# --- KYC Vendor (vendor-agnostic interface — swap = config change only) ---
KYC_VENDOR=persona                           # persona | jpm
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
JPM_KYC_API_URL=
JPM_KYC_API_KEY=
JPM_KYC_CLIENT_ID=

# --- Auth API (TCM-CRED-VERIFY-002) ---
# mTLS certificates — file paths to PEM files
MTLS_CA_CERT_PATH=./certs/ca.pem
MTLS_SERVER_CERT_PATH=./certs/server.pem
MTLS_SERVER_KEY_PATH=./certs/server.key
AUTH_API_RATE_LIMIT_REQUESTS=1000
AUTH_API_RATE_LIMIT_WINDOW_MS=300000         # 5 minutes

# --- NextAuth (portal) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Stripe (Gate 1 payment) ---
STRIPE_SECRET_KEY=sk_test_...               # Live: sk_live_... — never commit
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # Live: pk_live_...

# --- WalletConnect (portal wallet connector) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=       # From cloud.walletconnect.com

# --- Public RPC endpoints (portal client-side) ---
NEXT_PUBLIC_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_AMOY=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_MUMBAI=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY

# --- Wallet signature verification (API) ---
# DANGER: only valid in development/test. MUST be false in production.
SKIP_SIG_VERIFY=false                       # true only for local dev — never production

# --- Identity Vault Encryption ---
IDENTITY_VAULT_ENCRYPTION_KEY=              # AES-256 key — 32 bytes hex
IDENTITY_VAULT_SALT_MASTER=                 # Master salt for identity_binding

# --- Signing (ISSUER_ROLE wallet) ---
ISSUER_PRIVATE_KEY=                         # Hot wallet for ISSUER_ROLE — prod: HSM/KMS
ISSUER_WALLET_ADDRESS=

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# --- PagerDuty (reconciliation alerts) ---
PAGERDUTY_INTEGRATION_KEY_SEV1=
PAGERDUTY_INTEGRATION_KEY_SEV2=

# --- Reconciliation job intervals (ms) ---
RECON_MIRROR_VS_CHAIN_INTERVAL=300000       # 5 minutes
RECON_AUDIT_VS_MIRROR_INTERVAL=900000       # 15 minutes
RECON_BILLING_VS_EVENTS_INTERVAL=3600000    # 1 hour
