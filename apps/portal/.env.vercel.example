# ── Vercel demo deployment — paste these into Vercel → Settings → Environment Variables ──
#
# DEMO_MODE enables all simulation data. No database, Stripe, Persona, or wallet required.

DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# NextAuth — required even in demo mode
NEXTAUTH_URL=https://YOUR-PROJECT.vercel.app    # set to your actual Vercel URL after first deploy
NEXTAUTH_SECRET=any-random-string-32-chars-min  # generate: openssl rand -hex 32

# Leave everything else blank for demo — not needed
INTERNAL_API_URL=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_RPC_POLYGON=
