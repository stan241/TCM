# Portal-specific env vars — copy to .env.local
# NEVER commit .env.local

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Email (for OTP sign-in links — use Resend, SendGrid, or SMTP)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@tokencap.io

# Internal API (Node.js backend)
INTERNAL_API_URL=http://localhost:4000

# Public vars (exposed to browser — no secrets)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=get-from-cloud.walletconnect.com
NEXT_PUBLIC_PERSONA_TEMPLATE_ID=
NEXT_PUBLIC_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_AMOY=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_MUMBAI=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY

# Database (portal uses credential-mirror for session lookups)
DATABASE_URL_CREDENTIAL_MIRROR=postgresql://user:pass@localhost:5432/tcm_credential_mirror
